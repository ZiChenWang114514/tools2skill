#!/usr/bin/env python3
"""
t2s — tools2skill CLI
Manages the lifecycle of skills generated by the tools2skill methodology.

Commands:
  t2s install <name>              Install skill to ~/.claude/skills/ (hot-plug)
  t2s uninstall <name>            Remove skill from ~/.claude/skills/
  t2s list [--installed|--all]    List skills and their status
  t2s export <name> [--out <dir>] Bundle skill into a portable .t2s file
  t2s import <path_or_url>        Install skill from .t2s bundle
  t2s status                      Show full registry state
  t2s validate <name>             Check skill for portability rule violations
  t2s new-manifest <name>         Create a blank manifest for an existing skill
"""

import argparse
import json
import os
import shutil
import sys
import zipfile
import tempfile
import re
from datetime import datetime, timezone
from pathlib import Path


# ─── Paths ────────────────────────────────────────────────────────────────────

SCRIPT_DIR = Path(__file__).resolve().parent
SKILLS_DIR = SCRIPT_DIR / "skills"
SESSIONS_DIR = SCRIPT_DIR / "sessions"
REGISTRY_FILE = SCRIPT_DIR / "registry.json"
CLAUDE_SKILLS_DIR = Path.home() / ".claude" / "skills"

BUNDLE_EXT = ".t2s"
MANIFEST_SUFFIX = ".manifest.json"
SCHEMA_VERSION = "1.0"


# ─── Registry ─────────────────────────────────────────────────────────────────

def load_registry() -> dict:
    if REGISTRY_FILE.exists():
        with open(REGISTRY_FILE) as f:
            return json.load(f)
    return {"schema_version": SCHEMA_VERSION, "skills": {}}


def save_registry(reg: dict):
    reg["last_updated"] = datetime.now(timezone.utc).isoformat()
    with open(REGISTRY_FILE, "w") as f:
        json.dump(reg, f, indent=2, ensure_ascii=False)
        f.write("\n")


# ─── Manifest ─────────────────────────────────────────────────────────────────

def manifest_path(name: str) -> Path:
    return SKILLS_DIR / f"{name}{MANIFEST_SUFFIX}"


def skill_path(name: str) -> Path:
    return SKILLS_DIR / f"{name}.md"


def load_manifest(name: str) -> dict:
    p = manifest_path(name)
    if not p.exists():
        die(f"Manifest not found: {p}\nRun: t2s new-manifest {name}")
    with open(p) as f:
        return json.load(f)


def skill_exists(name: str) -> bool:
    return skill_path(name).exists()


# ─── Portability Validation ────────────────────────────────────────────────────

PORTABILITY_VIOLATIONS = [
    # Absolute paths to user home dirs
    (r"/home/\w+", "absolute home path"),
    (r"/Users/\w+", "absolute macOS home path"),
    (r"/root/", "root home path"),
    # Machine-specific paths (common patterns)
    (r"/data\d*/\w+", "machine-specific data path"),
    # Hardcoded usernames in paths
    (r"(?<!/)(zcwang|wangzc|admin|user1)\b", "hardcoded username"),
    # API keys / tokens
    (r"(?i)(api[_-]?key|token|secret|password)\s*[=:]\s*['\"]?\w{8,}", "potential secret"),
    # Local IP addresses
    (r"192\.168\.\d+\.\d+|127\.0\.0\.1:(?!8080|3000|5000)", "local IP address"),
]


def validate_portability(name: str) -> list[str]:
    """Returns list of violation messages. Empty = clean."""
    p = skill_path(name)
    if not p.exists():
        return [f"Skill file not found: {p}"]
    content = p.read_text()
    violations = []
    for pattern, label in PORTABILITY_VIOLATIONS:
        matches = re.findall(pattern, content)
        if matches:
            violations.append(f"[{label}] pattern '{pattern}' matched: {matches[:3]}")
    return violations


# ─── Commands ─────────────────────────────────────────────────────────────────

def cmd_install(name: str, force: bool = False):
    """Hot-plug a skill into ~/.claude/skills/."""
    if not skill_exists(name):
        die(f"Skill '{name}' not found in {SKILLS_DIR}/")

    # Portability check
    violations = validate_portability(name)
    if violations and not force:
        warn("Portability violations found (use --force to override):")
        for v in violations:
            warn(f"  {v}")
        die("Install aborted. Fix violations or use --force.")

    CLAUDE_SKILLS_DIR.mkdir(parents=True, exist_ok=True)
    dest = CLAUDE_SKILLS_DIR / f"{name}.md"
    shutil.copy2(skill_path(name), dest)

    # Update registry
    reg = load_registry()
    manifest = {}
    if manifest_path(name).exists():
        manifest = load_manifest(name)

    reg["skills"][name] = {
        "version": manifest.get("version", "unversioned"),
        "installed": True,
        "install_path": str(dest),
        "source_path": str(skill_path(name)),
        "installed_at": datetime.now(timezone.utc).isoformat(),
        "mastery_status": manifest.get("mastery_status", "unknown"),
        "tool_version_tested": manifest.get("tool_version_tested", "unknown"),
    }
    save_registry(reg)

    ok(f"Installed: {name} → {dest}")
    ok("Hot-plugged: skill is immediately available in new Claude Code sessions.")


def cmd_uninstall(name: str):
    """Remove a skill from ~/.claude/skills/."""
    dest = CLAUDE_SKILLS_DIR / f"{name}.md"
    if not dest.exists():
        die(f"Skill '{name}' is not installed at {dest}")

    dest.unlink()

    reg = load_registry()
    if name in reg["skills"]:
        reg["skills"][name]["installed"] = False
        reg["skills"][name]["uninstalled_at"] = datetime.now(timezone.utc).isoformat()
        del reg["skills"][name]["install_path"]
    save_registry(reg)

    ok(f"Uninstalled: {name} removed from {CLAUDE_SKILLS_DIR}")


def cmd_list(mode: str = "all"):
    """List skills and their install status."""
    reg = load_registry()
    local_skills = sorted(p.stem for p in SKILLS_DIR.glob("*.md"))
    installed = {CLAUDE_SKILLS_DIR / f"{name}.md" for name in local_skills}

    print(f"\n{'NAME':<20} {'STATUS':<14} {'VERSION':<12} {'MASTERY':<14} {'TOOL VER'}")
    print("─" * 75)

    for name in local_skills:
        is_installed = (CLAUDE_SKILLS_DIR / f"{name}.md").exists()
        if mode == "installed" and not is_installed:
            continue

        reg_entry = reg["skills"].get(name, {})
        version = reg_entry.get("version", "—")
        mastery = reg_entry.get("mastery_status", "—")
        tool_ver = reg_entry.get("tool_version_tested", "—")
        status = "\033[32mINSTALLED\033[0m" if is_installed else "\033[33mavailable\033[0m"

        print(f"{name:<20} {status:<23} {version:<12} {mastery:<14} {tool_ver}")

    print()
    total = len(local_skills)
    n_installed = sum(1 for n in local_skills if (CLAUDE_SKILLS_DIR / f"{n}.md").exists())
    print(f"{total} skills total, {n_installed} installed.")


def cmd_export(name: str, out_dir: str = "."):
    """Bundle skill + manifest + session log into a portable .t2s file."""
    if not skill_exists(name):
        die(f"Skill '{name}' not found.")

    violations = validate_portability(name)
    if violations:
        warn("Portability violations in skill (bundle may not be portable on other machines):")
        for v in violations:
            warn(f"  {v}")

    out_path = Path(out_dir) / f"{name}{BUNDLE_EXT}"

    with zipfile.ZipFile(out_path, "w", zipfile.ZIP_DEFLATED) as zf:
        # skill.md (required)
        zf.write(skill_path(name), "skill.md")

        # manifest.json (required — generate minimal one if missing)
        m_path = manifest_path(name)
        if m_path.exists():
            zf.write(m_path, "manifest.json")
        else:
            warn(f"No manifest found for '{name}'. Generating minimal manifest.")
            minimal = _generate_minimal_manifest(name)
            zf.writestr("manifest.json", json.dumps(minimal, indent=2))

        # session_log.md (optional — find most recent matching session)
        session_log = _find_session_log(name)
        if session_log:
            zf.write(session_log, "session_log.md")
            info(f"Including session log: {session_log.name}")
        else:
            info("No session log found — bundle will not include one.")

        # bundle_meta.json
        bundle_meta = {
            "bundled_at": datetime.now(timezone.utc).isoformat(),
            "t2s_schema_version": SCHEMA_VERSION,
            "tool": name,
        }
        zf.writestr("bundle_meta.json", json.dumps(bundle_meta, indent=2))

    ok(f"Exported: {out_path} ({out_path.stat().st_size} bytes)")
    ok("Share this .t2s file. Recipients can install with: t2s import <path>")


def cmd_import(source: str):
    """Install a skill from a .t2s bundle (file path or URL)."""
    # Handle URL download
    bundle_path = Path(source)
    tmp_dir = None

    if source.startswith("http://") or source.startswith("https://"):
        import urllib.request
        tmp_dir = Path(tempfile.mkdtemp())
        bundle_path = tmp_dir / Path(source).name
        info(f"Downloading {source} ...")
        urllib.request.urlretrieve(source, bundle_path)

    if not bundle_path.exists():
        die(f"Bundle not found: {bundle_path}")

    if not zipfile.is_zipfile(bundle_path):
        die(f"Not a valid .t2s bundle: {bundle_path}")

    with zipfile.ZipFile(bundle_path, "r") as zf:
        names = zf.namelist()
        if "skill.md" not in names:
            die("Bundle is malformed: missing skill.md")

        # Read manifest to get tool name
        if "manifest.json" in names:
            manifest = json.loads(zf.read("manifest.json"))
            tool_name = manifest.get("name") or manifest.get("tool_name")
        else:
            # Infer from bundle filename
            tool_name = bundle_path.stem
            manifest = _generate_minimal_manifest(tool_name)
            warn(f"No manifest in bundle. Using inferred name: {tool_name}")

        if not tool_name:
            die("Cannot determine skill name from bundle. Malformed manifest.")

        # Extract skill.md to skills/
        SKILLS_DIR.mkdir(exist_ok=True)
        dest_skill = SKILLS_DIR / f"{tool_name}.md"
        dest_skill.write_bytes(zf.read("skill.md"))

        # Extract manifest
        dest_manifest = manifest_path(tool_name)
        if "manifest.json" in names:
            dest_manifest.write_bytes(zf.read("manifest.json"))
        else:
            dest_manifest.write_text(json.dumps(manifest, indent=2))

        # Extract session log if present
        if "session_log.md" in names:
            session_dest = SESSIONS_DIR / f"imported_{tool_name}"
            session_dest.mkdir(exist_ok=True)
            (session_dest / "session_log.md").write_bytes(zf.read("session_log.md"))
            info(f"Session log extracted to {session_dest}/")

    ok(f"Imported: {tool_name} → {dest_skill}")
    info("To hot-plug into Claude Code: t2s install " + tool_name)

    if tmp_dir:
        shutil.rmtree(tmp_dir)


def cmd_status():
    """Show full registry state."""
    reg = load_registry()
    print(f"\ntools2skill Registry — schema v{reg.get('schema_version', '?')}")
    print(f"Last updated: {reg.get('last_updated', 'never')}")
    print(f"Claude skills dir: {CLAUDE_SKILLS_DIR}")
    print()

    if not reg["skills"]:
        print("No skills registered yet. Run a tools2skill session to generate skills.")
        return

    for name, entry in reg["skills"].items():
        installed = entry.get("installed", False)
        marker = "✓" if installed else "○"
        print(f"  {marker} {name}")
        for k, v in entry.items():
            if k != "installed":
                print(f"      {k}: {v}")
        print()


def cmd_validate(name: str):
    """Check skill for portability violations."""
    violations = validate_portability(name)
    if violations:
        warn(f"Portability violations in '{name}':")
        for v in violations:
            print(f"  ✗ {v}")
        sys.exit(1)
    else:
        ok(f"'{name}' passed all portability checks.")


def cmd_new_manifest(name: str):
    """Create a blank manifest.json for an existing skill."""
    if not skill_exists(name):
        die(f"Skill '{name}' not found in {SKILLS_DIR}/. Create the skill file first.")

    dest = manifest_path(name)
    if dest.exists():
        die(f"Manifest already exists: {dest}")

    manifest = {
        "schema_version": SCHEMA_VERSION,
        "name": name,
        "version": "1.0.0",
        "tool_name": name,
        "tool_version_tested": "FILL_IN",
        "tool_type": "CLI | Python lib | REST API | SDK | Config | Other",
        "mastery_status": "MASTERED | PARTIAL MASTERY | BETA",
        "mastery_metrics": {
            "M1_use_case_coverage": 0.0,
            "M2_qa_confidence_rate": 0.0,
            "M3_gotcha_density": 0,
            "M5_skill_tokens": 0
        },
        "session_id": f"YYYY-MM-DD_{name}",
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "author": "tools2skill/claude",
        "triggers": [name],
        "dependencies": [],
        "tags": [],
        "description": f"Expert operational guide for {name}.",
        "known_gaps": [],
        "portability": {
            "machine_specific": False,
            "requires_local_setup": False,
            "notes": ""
        }
    }

    dest.write_text(json.dumps(manifest, indent=2, ensure_ascii=False) + "\n")
    ok(f"Created manifest: {dest}")
    info("Fill in the FILL_IN fields, then run: t2s install " + name)


# ─── Helpers ──────────────────────────────────────────────────────────────────

def _generate_minimal_manifest(name: str) -> dict:
    return {
        "schema_version": SCHEMA_VERSION,
        "name": name,
        "version": "unversioned",
        "tool_name": name,
        "tool_version_tested": "unknown",
        "mastery_status": "unknown",
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "author": "tools2skill",
    }


def _find_session_log(name: str) -> Path | None:
    """Find the most recent session directory for this tool."""
    if not SESSIONS_DIR.exists():
        return None
    candidates = sorted(
        [d for d in SESSIONS_DIR.iterdir() if d.is_dir() and name in d.name],
        key=lambda d: d.stat().st_mtime,
        reverse=True
    )
    if not candidates:
        return None
    # Look for a session log file inside
    for fname in ["phase4_skill.md", "session_log.md", "session_template.md"]:
        p = candidates[0] / fname
        if p.exists():
            return p
    return None


def ok(msg: str):
    print(f"\033[32m✓\033[0m {msg}")


def warn(msg: str):
    print(f"\033[33m⚠\033[0m {msg}", file=sys.stderr)


def info(msg: str):
    print(f"  {msg}")


def die(msg: str):
    print(f"\033[31m✗\033[0m {msg}", file=sys.stderr)
    sys.exit(1)


# ─── CLI Entry Point ───────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="t2s",
        description="tools2skill skill lifecycle manager",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  t2s install pytest           # hot-plug pytest skill into Claude Code
  t2s uninstall pytest         # remove from active Claude Code skills
  t2s list                     # show all available skills
  t2s list --installed         # show only installed skills
  t2s export pytest            # create pytest.t2s bundle for sharing
  t2s export pytest --out /tmp # export to specific directory
  t2s import pytest.t2s        # install from bundle
  t2s import https://...       # install from URL
  t2s validate pytest          # check for portability violations
  t2s status                   # full registry dump
  t2s new-manifest pytest      # create manifest for existing skill
        """
    )
    sub = parser.add_subparsers(dest="cmd", metavar="command")

    # install
    p_install = sub.add_parser("install", help="Hot-plug skill into Claude Code")
    p_install.add_argument("name", help="Skill name (must exist in skills/)")
    p_install.add_argument("--force", action="store_true", help="Override portability warnings")

    # uninstall
    p_uninstall = sub.add_parser("uninstall", help="Remove skill from Claude Code")
    p_uninstall.add_argument("name")

    # list
    p_list = sub.add_parser("list", help="List skills")
    p_list.add_argument("--installed", action="store_true", help="Show only installed skills")

    # export
    p_export = sub.add_parser("export", help="Bundle skill into portable .t2s file")
    p_export.add_argument("name")
    p_export.add_argument("--out", default=".", metavar="DIR", help="Output directory")

    # import
    p_import = sub.add_parser("import", help="Install skill from .t2s bundle")
    p_import.add_argument("source", help="Path or URL to .t2s bundle")

    # status
    sub.add_parser("status", help="Show full registry state")

    # validate
    p_validate = sub.add_parser("validate", help="Check skill portability")
    p_validate.add_argument("name")

    # new-manifest
    p_nm = sub.add_parser("new-manifest", help="Create manifest for existing skill")
    p_nm.add_argument("name")

    args = parser.parse_args()

    if args.cmd == "install":
        cmd_install(args.name, force=args.force)
    elif args.cmd == "uninstall":
        cmd_uninstall(args.name)
    elif args.cmd == "list":
        cmd_list(mode="installed" if args.installed else "all")
    elif args.cmd == "export":
        cmd_export(args.name, out_dir=args.out)
    elif args.cmd == "import":
        cmd_import(args.source)
    elif args.cmd == "status":
        cmd_status()
    elif args.cmd == "validate":
        cmd_validate(args.name)
    elif args.cmd == "new-manifest":
        cmd_new_manifest(args.name)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
